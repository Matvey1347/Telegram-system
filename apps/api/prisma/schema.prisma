generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum TransactionType {
  income
  expense
}

enum CurrencyDisplayMode {
  code
  symbol
}

enum CampaignStatus {
  planned
  active
  finished
  cancelled
  archived
}

enum PromoStatus {
  draft
  active
  archived
}

enum TelegramUserAccountStatus {
  pending
  needs_code
  needs_password
  connected
  error
  disabled
}

enum TelegramSourceType {
  BOT
  MTPROTO
}

enum TelegramChannelSourceRole {
  OWNER
  ADMIN
  MEMBER
  UNKNOWN
}

enum TelegramChannelDataType {
  CHANNEL_INFO
  POSTS
  INVITE_LINKS
  STATS
  MEMBERS
  REACTIONS
  VIEWS
  OTHER
}

enum TelegramDataSourceStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

enum AdvertisingSourceType {
  telegram_channel
  instagram
  facebook
  website
  direct
  other
}

enum IconType {
  emoji
  image
}

enum TelegramChannelAdAnalysisStatus {
  NEW
  APPROVED
  REJECTED
  WATCH_LATER
  BLACKLIST
  TESTED
}

enum TelegramManagedPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum TelegramManagedPostRemoteStatus {
  NONE
  SCHEDULED
  PUBLISHED
  BROKEN
  MISSING
  UNKNOWN
}

model User {
  id                             String                           @id @default(cuid())
  email                          String                           @unique
  seedKey                        String?                          @unique
  passwordHash                   String
  name                           String
  memberships                    WorkspaceMember[]
  icons                          Icon[]
  createdAccounts                Account[]                        @relation("AccountCreatedBy")
  createdTransactions            Transaction[]                    @relation("TransactionCreatedBy")
  createdTransfers               Transfer[]                       @relation("TransferCreatedBy")
  createdInvestments             Investment[]                     @relation("InvestmentCreatedBy")
  createdTelegramChannels        TelegramChannel[]                @relation("TelegramChannelCreatedBy")
  createdTelegramBots            TelegramBotIntegration[]         @relation("TelegramBotCreatedBy")
  createdTelegramUserAccounts    TelegramUserAccountIntegration[] @relation("TelegramUserAccountCreatedBy")
  createdPromos                  Promo[]                          @relation("PromoCreatedBy")
  createdAdvertisingSources      AdvertisingSource[]              @relation("AdvertisingSourceCreatedBy")
  createdAdCampaigns             AdCampaign[]                     @relation("AdCampaignCreatedBy")
  createdAdHypotheses            AdHypothesis[]                   @relation("AdHypothesisCreatedBy")
  createdTelegramChannelNetworks TelegramChannelNetwork[]         @relation("TelegramChannelNetworkCreatedBy")
  createdAt                      DateTime                         @default(now())
  updatedAt                      DateTime                         @updatedAt
}

model Workspace {
  id                  String              @id @default(cuid())
  name                String
  primaryCurrency     String              @default("USD") @db.VarChar(3)
  secondaryCurrency   String              @default("UAH") @db.VarChar(3)
  currencyDisplayMode CurrencyDisplayMode @default(code)
  avatarIconId        String?

  members                          WorkspaceMember[]
  accounts                         Account[]
  transactions                     Transaction[]
  transfers                        Transfer[]
  telegramChannels                 TelegramChannel[]
  telegramBotIntegrations          TelegramBotIntegration[]
  telegramUserAccountIntegrations  TelegramUserAccountIntegration[]
  telegramChannelAdminLinks        TelegramChannelAdminLink[]
  telegramChannelSourceAccesses    TelegramChannelSourceAccess[]
  telegramChannelDataSources       TelegramChannelDataSource[]
  telegramChannelStatsSnapshots    TelegramChannelStatsSnapshot[]
  telegramChannelAudienceSnapshots TelegramChannelAudienceSnapshot[]
  telegramChannelNetworks          TelegramChannelNetwork[]
  telegramChannelNetworkMembers    TelegramChannelNetworkMember[]
  telegramChannelStatsPoints       TelegramChannelStatsPoint[]
  telegramChannelAdAnalyses        TelegramChannelAdAnalysis[]
  telegramPosts                    TelegramPost[]
  telegramManagedPosts             TelegramManagedPost[]
  postGroups                       PostGroup[]
  promos                           Promo[]
  advertisingSources               AdvertisingSource[]
  adCampaigns                      AdCampaign[]
  adHypotheses                     AdHypothesis[]
  adHypothesisCampaigns            AdHypothesisCampaign[]
  dailyAnalyticsSyncRuns           DailyAnalyticsSyncRun[]
  exchangeRates                    ExchangeRate[]
  investments                      Investment[]
  transactionCategories            TransactionCategory[]
  icons                            Icon[]
  promptNotes                      PromptNote[]
  avatarIcon                       Icon?                             @relation("WorkspaceAvatarIcon", fields: [avatarIconId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptNote {
  id          String @id @default(cuid())
  workspaceId String
  title       String
  content     String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, updatedAt])
}

model TelegramUserAccountIntegration {
  id                        String                    @id @default(cuid())
  workspaceId               String
  assignedMemberId          String?
  createdByUserId           String?
  label                     String
  apiId                     String
  apiHashEncrypted          String
  apiHashIv                 String
  apiHashAuthTag            String
  phoneMasked               String?
  phoneEncrypted            String?
  phoneIv                   String?
  phoneAuthTag              String?
  telegramUserId            String?
  username                  String?
  firstName                 String?
  lastName                  String?
  photoUrl                  String?
  nameColor                 Int?
  status                    TelegramUserAccountStatus @default(pending)
  lastErrorMessage          String?
  lastCheckedAt             DateTime?
  lastSyncedAt              DateTime?
  isActive                  Boolean                   @default(true)
  sessionEncrypted          String?
  sessionIv                 String?
  sessionAuthTag            String?
  loginPhoneCodeHash        String?
  loginTempSessionEncrypted String?
  loginTempSessionIv        String?
  loginTempSessionAuthTag   String?
  loginStartedAt            DateTime?

  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedMember    WorkspaceMember?           @relation("TelegramUserAccountAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser     User?                      @relation("TelegramUserAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  channelAdminLinks TelegramChannelAdminLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model TelegramChannelAdminLink {
  id                               String @id @default(cuid())
  workspaceId                      String
  telegramChannelId                String
  telegramUserAccountIntegrationId String
  source                           String @default("mtproto")

  workspace                      Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel                TelegramChannel                @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  telegramUserAccountIntegration TelegramUserAccountIntegration @relation(fields: [telegramUserAccountIntegrationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, telegramChannelId, telegramUserAccountIntegrationId])
  @@index([workspaceId, telegramChannelId])
  @@index([workspaceId, telegramUserAccountIntegrationId])
}

model TelegramChannelSourceAccess {
  id                   String                    @id @default(cuid())
  workspaceId          String
  channelId            String
  sourceId             String
  sourceType           TelegramSourceType
  role                 TelegramChannelSourceRole @default(UNKNOWN)
  canPostMessages      Boolean                   @default(false)
  canEditMessages      Boolean                   @default(false)
  canDeleteMessages    Boolean                   @default(false)
  canInviteUsers       Boolean                   @default(false)
  canManageInviteLinks Boolean                   @default(false)
  canViewStats         Boolean                   @default(false)
  rawPermissions       Json?
  lastCheckedAt        DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, sourceId, sourceType])
  @@index([workspaceId, channelId])
  @@index([workspaceId, sourceId, sourceType])
}

model TelegramChannelDataSource {
  id                String                   @id @default(cuid())
  workspaceId       String
  channelId         String
  sourceId          String
  sourceType        TelegramSourceType
  dataType          TelegramChannelDataType
  status            TelegramDataSourceStatus @default(SUCCESS)
  sourceDisplayName String?
  errorMessage      String?
  metadata          Json?
  syncedAt          DateTime                 @default(now())
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel   TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([workspaceId, channelId])
  @@index([workspaceId, sourceId, sourceType])
  @@index([workspaceId, channelId, dataType])
}

model WorkspaceMember {
  id           String        @id @default(cuid())
  workspaceId  String
  userId       String
  role         WorkspaceRole @default(admin)
  avatarIconId String?

  workspace                         Workspace                        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                              User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarIcon                        Icon?                            @relation(fields: [avatarIconId], references: [id], onDelete: SetNull)
  investments                       Investment[]
  investmentTransactions            Transaction[]                    @relation("MemberInvestmentTransactions")
  assignedAccounts                  Account[]                        @relation("AccountAssignedMember")
  assignedTransactions              Transaction[]                    @relation("TransactionAssignedMember")
  assignedTransfers                 Transfer[]                       @relation("TransferAssignedMember")
  assignedInvestments               Investment[]                     @relation("InvestmentAssignedMember")
  assignedTelegramChannels          TelegramChannel[]                @relation("TelegramChannelAssignedMember")
  assignedTelegramBots              TelegramBotIntegration[]         @relation("TelegramBotAssignedMember")
  assignedTelegramUserAccounts      TelegramUserAccountIntegration[] @relation("TelegramUserAccountAssignedMember")
  assignedPromos                    Promo[]                          @relation("PromoAssignedMember")
  assignedAdvertisingSources        AdvertisingSource[]              @relation("AdvertisingSourceAssignedMember")
  assignedAdCampaigns               AdCampaign[]                     @relation("AdCampaignAssignedMember")
  assignedAdHypotheses              AdHypothesis[]                   @relation("AdHypothesisAssignedMember")
  assignedTelegramChannelNetworks   TelegramChannelNetwork[]         @relation("TelegramChannelNetworkAssignedMember")
  assignedTelegramChannelAdAnalyses TelegramChannelAdAnalysis[]      @relation("TelegramChannelAdAnalysisAssignedMember")
  assignedTelegramManagedPosts      TelegramManagedPost[]            @relation("TelegramManagedPostAssignedMember")
  createdPostGroups                 PostGroup[]                      @relation("PostGroupCreatedByMember")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@unique([id, workspaceId])
}

model Account {
  id               String  @id @default(cuid())
  workspaceId      String
  name             String
  currency         String  @db.VarChar(3)
  initialBalance   Decimal @default(0)
  isActive         Boolean @default(true)
  iconId           String?
  assignedMemberId String?
  createdByUserId  String?

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  icon           Icon?            @relation(fields: [iconId], references: [id], onDelete: SetNull)
  assignedMember WorkspaceMember? @relation("AccountAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("AccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  transactions      Transaction[]
  outgoingTransfers Transfer[]    @relation("OutgoingTransfers")
  incomingTransfers Transfer[]    @relation("IncomingTransfers")
  adCampaigns       AdCampaign[]
  investments       Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model Transaction {
  id                      String          @id @default(cuid())
  workspaceId             String
  accountId               String
  type                    TransactionType
  amount                  Decimal
  currency                String          @db.VarChar(3)
  amountInPrimaryCurrency Decimal
  exchangeRateToPrimary   Decimal
  category                String
  categoryId              String?
  memberId                String?
  description             String?
  date                    DateTime
  adCampaignId            String?         @unique
  createdByUserId         String?
  iconId                  String?
  assignedMemberId        String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)

  adCampaign     AdCampaign?          @relation("CampaignExpenseTransaction", fields: [adCampaignId], references: [id])
  investment     Investment?
  categoryRef    TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  member         WorkspaceMember?     @relation("MemberInvestmentTransactions", fields: [memberId], references: [id], onDelete: SetNull)
  icon           Icon?                @relation(fields: [iconId], references: [id], onDelete: SetNull)
  assignedMember WorkspaceMember?     @relation("TransactionAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?                @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, type, categoryId])
  @@index([workspaceId, memberId])
  @@index([workspaceId, assignedMemberId])
}

model TransactionCategory {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  type        TransactionType
  isSystem    Boolean         @default(false)
  key         String?
  iconId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  transactions Transaction[] @relation
  icon         Icon?         @relation(fields: [iconId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, type, key])
  @@index([workspaceId, type])
}

model Investment {
  id                      String   @id @default(cuid())
  workspaceId             String
  workspaceMemberId       String
  accountId               String
  transactionId           String?  @unique
  amount                  Decimal
  currency                String   @db.VarChar(3)
  amountInPrimaryCurrency Decimal
  exchangeRateToPrimary   Decimal
  date                    DateTime
  notes                   String?
  createdByUserId         String?
  assignedMemberId        String?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceMember WorkspaceMember  @relation(fields: [workspaceMemberId], references: [id], onDelete: Restrict)
  account         Account          @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transaction     Transaction?     @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  assignedMember  WorkspaceMember? @relation("InvestmentAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser   User?            @relation("InvestmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model Transfer {
  id                   String   @id @default(cuid())
  workspaceId          String
  fromAccountId        String
  toAccountId          String
  fromAmount           Decimal
  fromCurrency         String   @db.VarChar(3)
  toAmount             Decimal
  toCurrency           String   @db.VarChar(3)
  exchangeRate         Decimal?
  expectedToAmount     Decimal?
  transferLossAmount   Decimal?
  transferLossCurrency String?  @db.VarChar(3)
  date                 DateTime
  description          String?
  createdByUserId      String?
  assignedMemberId     String?

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromAccount    Account          @relation("OutgoingTransfers", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount      Account          @relation("IncomingTransfers", fields: [toAccountId], references: [id], onDelete: Restrict)
  assignedMember WorkspaceMember? @relation("TransferAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("TransferCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model TelegramChannel {
  id                        String   @id @default(cuid())
  workspaceId               String
  title                     String
  username                  String?
  telegramChatId            String?
  inviteLink                String?
  description               String?
  language                  String?
  niche                     String?
  currentSubscribersCount   Int?
  seedSubscribersCount      Int      @default(0)
  activeSubscribersWindow   Int      @default(5)
  knownFakeSubscribersCount Int      @default(0)
  ownViewsPerPost           Int      @default(0)
  ownReactionsPerPost       Int      @default(0)
  subscriberBaseQuality     String   @default("normal")
  dataQualityNotes          String?
  targetCpaFrom             Decimal?
  targetCpa                 Decimal?
  acceptableCpaFrom         Decimal?
  acceptableCpa             Decimal?
  stopCpaFrom               Decimal?
  stopCpa                   Decimal?
  isActive                  Boolean  @default(true)
  assignedMemberId          String?
  createdByUserId           String?

  photoSmallFileId   String?
  photoBigFileId     String?
  photoUrl           String?
  sourceType         String?   @default("telegram")
  lastPublicSyncedAt DateTime?

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedMember WorkspaceMember? @relation("TelegramChannelAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("TelegramChannelCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  promos            Promo[]
  adCampaigns       AdCampaign[]
  adPlacements      AdCampaignTelegramChannelPlacement[]
  inviteLinks       TelegramInviteLink[]
  dailyStats        TelegramChannelDailyStats[]
  adminLinks        TelegramChannelAdminLink[]
  sourceAccesses    TelegramChannelSourceAccess[]
  dataSources       TelegramChannelDataSource[]
  posts             TelegramPost[]
  managedPosts      TelegramManagedPost[]
  postGroups        PostGroup[]
  statsSnapshots    TelegramChannelStatsSnapshot[]
  audienceSnapshots TelegramChannelAudienceSnapshot[]
  networkMembers    TelegramChannelNetworkMember[]
  statsPoints       TelegramChannelStatsPoint[]
  adAnalyses        TelegramChannelAdAnalysis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, username])
  @@index([workspaceId, telegramChatId])
  @@index([workspaceId, assignedMemberId])
}

model TelegramChannelAdAnalysis {
  id                String                          @id @default(cuid())
  workspaceId       String
  telegramChannelId String
  assignedMemberId  String?
  analyzedAt        DateTime                        @default(now())
  status            TelegramChannelAdAnalysisStatus @default(WATCH_LATER)
  verdict           String?
  price             Decimal?
  currency          String                          @default("USD") @db.VarChar(3)
  avgViews          Float?
  avgReactions      Float?
  avgForwards       Float?
  postsCount        Int?
  cpm               Decimal?
  reasonTags        String[]                        @default([])
  reasonSummary     String?
  notes             String?
  nextReviewAt      DateTime?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel  @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  assignedMember  WorkspaceMember? @relation("TelegramChannelAdAnalysisAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, telegramChannelId])
  @@index([workspaceId, analyzedAt])
  @@index([workspaceId, status])
  @@index([workspaceId, assignedMemberId])
}

model TelegramChannelDailyStats {
  id                String   @id @default(cuid())
  telegramChannelId String
  date              DateTime
  subscribersCount  Int?
  joinedCount       Int?
  leftCount         Int?
  netGrowthCount    Int?
  viewsCount        Int?
  reactionsCount    Int?
  forwardsCount     Int?

  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([telegramChannelId, date])
}

model TelegramChannelStatsSnapshot {
  id                String   @id @default(cuid())
  workspaceId       String
  telegramChannelId String
  syncedAt          DateTime @default(now())
  snapshotDate      DateTime @db.Date
  rawStats          Json
  normalizedStats   Json
  availableFields   String[] @default([])
  warnings          String[] @default([])

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([telegramChannelId, snapshotDate])
  @@index([workspaceId, telegramChannelId, syncedAt])
}

model TelegramChannelStatsPoint {
  id                String   @id @default(cuid())
  workspaceId       String
  telegramChannelId String
  metric            String
  series            String
  seriesLabel       String
  color             String?
  graphType         String
  date              DateTime @db.Date
  value             Float
  latestSyncedAt    DateTime @default(now())

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([telegramChannelId, metric, series, date])
  @@index([workspaceId, telegramChannelId, date])
}

model TelegramChannelAudienceSnapshot {
  id                              String   @id @default(cuid())
  workspaceId                     String
  telegramChannelId               String
  collectedAt                     DateTime @default(now())
  subscribersCount                Int?
  activeSubscribersEstimate       Int?
  viewRate                        Float?
  avgViewsRaw                     Float?
  avgViewsAdjusted                Float?
  avgReactionsRaw                 Float?
  avgReactionsAdjusted            Float?
  rawAvgViews                     Float?
  rawAvgReactions                 Float?
  rawViewRate                     Float?
  effectiveSubscribersCount       Int?
  cappedActiveSubscribersEstimate Int?
  cappedViewRate                  Float?
  dataQuality                     String   @default("normal")
  dataQualityReason               String?
  hasExternalTrafficAnomaly       Boolean  @default(false)
  hasSubscriberBasePollution      Boolean  @default(false)
  postsWindow                     Int
  source                          String   @default("sync")
  createdAt                       DateTime @default(now())

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  @@index([workspaceId, telegramChannelId, collectedAt])
  @@index([telegramChannelId, collectedAt])
}

model TelegramChannelNetwork {
  id               String  @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  assignedMemberId String?
  createdByUserId  String?

  workspace      Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels       TelegramChannelNetworkMember[]
  assignedMember WorkspaceMember?               @relation("TelegramChannelNetworkAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?                          @relation("TelegramChannelNetworkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, assignedMemberId])
}

model TelegramChannelNetworkMember {
  id                String @id @default(cuid())
  workspaceId       String
  networkId         String
  telegramChannelId String

  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  network         TelegramChannelNetwork @relation(fields: [networkId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel        @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([networkId, telegramChannelId])
  @@index([workspaceId])
  @@index([networkId])
  @@index([telegramChannelId])
}

model Promo {
  id                String      @id @default(cuid())
  workspaceId       String
  telegramChannelId String
  title             String
  text              String
  angle             String?
  imageData         String?
  status            PromoStatus @default(draft)
  assignedMemberId  String?
  createdByUserId   String?

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel  @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  assignedMember  WorkspaceMember? @relation("PromoAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser   User?            @relation("PromoCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  adCampaigns AdCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model AdvertisingSource {
  id               String                @id @default(cuid())
  workspaceId      String
  name             String
  type             AdvertisingSourceType @default(telegram_channel)
  url              String?
  telegramUsername String?
  description      String?
  contactInfo      String?
  notes            String?
  imageUrl         String?
  subscribersCount Int                   @default(0)
  channelTags      String[]              @default([])
  assignedMemberId String?
  createdByUserId  String?

  workspace         Workspace                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  adCampaignsLegacy AdCampaign[]
  adCampaigns       AdCampaignAdvertisingChannel[]
  assignedMember    WorkspaceMember?               @relation("AdvertisingSourceAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser     User?                          @relation("AdvertisingSourceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model AdCampaign {
  id                  String  @id @default(cuid())
  workspaceId         String
  telegramChannelId   String
  advertisingSourceId String?
  promoId             String?
  accountId           String?

  title                         String
  status                        CampaignStatus @default(planned)
  price                         Decimal
  currency                      String         @db.VarChar(3)
  priceInPrimaryCurrency        Decimal
  exchangeRateToPrimary         Decimal
  inviteLink                    String?
  telegramInviteLinkId          String?
  sourcePostUrl                 String?
  sourcePostViews               Int?
  startedAt                     DateTime?
  endedAt                       DateTime?
  placementDate                 DateTime?
  joinedCount                   Int            @default(0)
  leftCount                     Int?
  netGrowthCount                Int?
  cpa                           Decimal?
  cpm                           Decimal?
  subscribersBefore             Int?
  avgViewsBefore                Float?
  avgReactionsBefore            Float?
  subscribersAfter24h           Int?
  subscribersAfter48h           Int?
  subscribersAfter72h           Int?
  subscribersAfter7d            Int?
  subscribersAfter30d           Int?
  avgViewsAfter                 Float?
  avgReactionsAfter             Float?
  clicksAfter                   Int?
  newSubscribers                Int?
  activeSubscribersFromAd       Int?
  activeCpa                     Decimal?
  activeRate                    Float?
  rawActiveSubscribersFromAd    Int?
  rawViewRateAfter              Float?
  cappedActiveSubscribersFromAd Int?
  cappedActiveRate              Float?
  cappedActiveCpa               Decimal?
  cappedViewRateAfter           Float?
  adDataQuality                 String         @default("normal")
  adDataQualityReason           String?
  hasViewAnomaly                Boolean        @default(false)
  hasSubscriberBasePollution    Boolean        @default(false)
  unsub24h                      Int?
  unsub48h                      Int?
  unsub72h                      Int?
  unsub7d                       Int?
  unsub30d                      Int?
  retention24h                  Float?
  retention48h                  Float?
  retention72h                  Float?
  retention7d                   Float?
  retention30d                  Float?
  cpaStatus                     String?
  activeCpaStatus               String?
  retentionStatus               String?
  overallStatus                 String?
  decisionText                  String?
  excludeFromAnalytics          Boolean        @default(false)
  analyticsNotes                String?
  analyticsLastCalculatedAt     DateTime?
  analyticsLastAutoSyncedAt     DateTime?
  analyticsLastManualSyncedAt   DateTime?
  notes                         String?
  createdByUserId               String?
  assignedMemberId              String?

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel   TelegramChannel    @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  advertisingSource AdvertisingSource? @relation(fields: [advertisingSourceId], references: [id], onDelete: SetNull)
  promo             Promo?             @relation(fields: [promoId], references: [id], onDelete: SetNull)
  account           Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)
  assignedMember    WorkspaceMember?   @relation("AdCampaignAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser     User?              @relation("AdCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  expenseTransaction          Transaction?                         @relation("CampaignExpenseTransaction")
  advertisingChannels         AdCampaignAdvertisingChannel[]
  advertisingTelegramChannels AdCampaignTelegramChannelPlacement[]
  hypothesisLinks             AdHypothesisCampaign[]

  inviteLinks TelegramInviteLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, assignedMemberId])
}

model AdHypothesis {
  id               String  @id @default(cuid())
  workspaceId      String
  name             String
  description      String?
  status           String  @default("testing")
  conclusion       String?
  assignedMemberId String?
  createdByUserId  String?

  workspace      Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns      AdHypothesisCampaign[]
  assignedMember WorkspaceMember?       @relation("AdHypothesisAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?                  @relation("AdHypothesisCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, assignedMemberId])
}

model AdHypothesisCampaign {
  id           String @id @default(cuid())
  workspaceId  String
  hypothesisId String
  adCampaignId String

  workspace  Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  hypothesis AdHypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  adCampaign AdCampaign   @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([hypothesisId, adCampaignId])
  @@index([workspaceId])
  @@index([hypothesisId])
  @@index([adCampaignId])
}

model DailyAnalyticsSyncRun {
  id                 String    @id @default(cuid())
  workspaceId        String?
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  status             String    @default("running")
  source             String    @default("cron")
  channelsProcessed  Int       @default(0)
  campaignsProcessed Int       @default(0)
  snapshotsCreated   Int       @default(0)
  errorsCount        Int       @default(0)
  errorMessage       String?
  createdAt          DateTime  @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
  @@index([status])
  @@index([source])
}

model AdCampaignAdvertisingChannel {
  id                  String   @id @default(cuid())
  adCampaignId        String
  advertisingSourceId String
  createdAt           DateTime @default(now())

  adCampaign        AdCampaign        @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  advertisingSource AdvertisingSource @relation(fields: [advertisingSourceId], references: [id], onDelete: Cascade)

  @@unique([adCampaignId, advertisingSourceId])
  @@index([advertisingSourceId])
}

model AdCampaignTelegramChannelPlacement {
  id                String   @id @default(cuid())
  adCampaignId      String
  telegramChannelId String
  createdAt         DateTime @default(now())

  adCampaign      AdCampaign      @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  @@unique([adCampaignId, telegramChannelId])
  @@index([telegramChannelId])
}

model TelegramInviteLink {
  id                   String    @id @default(cuid())
  workspaceId          String
  telegramChannelId    String
  adCampaignId         String?
  name                 String
  url                  String
  telegramInviteLinkId String?
  createdBy            String?
  createsJoinRequest   Boolean?
  expireDate           DateTime?
  memberLimit          Int?
  joinedCount          Int       @default(0)
  isRevoked            Boolean   @default(false)
  lastSyncedAt         DateTime?

  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  adCampaign      AdCampaign?     @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramBotIntegration {
  id                String    @id @default(cuid())
  workspaceId       String
  label             String
  botTokenEncrypted String
  botTokenIv        String
  botTokenAuthTag   String
  botTokenMasked    String
  botId             String?
  username          String?
  firstName         String?
  lastErrorMessage  String?
  lastCheckedAt     DateTime?
  isActive          Boolean   @default(true)
  assignedMemberId  String?
  createdByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedMember WorkspaceMember? @relation("TelegramBotAssignedMember", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  createdByUser  User?            @relation("TelegramBotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, assignedMemberId])
}

model TelegramPost {
  id                   String   @id @default(cuid())
  workspaceId          String
  telegramChannelId    String
  telegramMessageId    String
  text                 String?
  postDate             DateTime
  viewsCount           Int?
  forwardsCount        Int?
  reactionsCount       Int?
  commentsCount        Int?
  manualOwnViews       Int      @default(0)
  manualOwnReactions   Int      @default(0)
  excludeFromAnalytics Boolean  @default(false)
  reactions            Json?
  rawMessage           Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace       Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel              @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  metricSnapshots TelegramPostMetricSnapshot[]

  @@unique([telegramChannelId, telegramMessageId])
  @@index([telegramChannelId, postDate])
  @@index([workspaceId, telegramChannelId, postDate])
}

model TelegramManagedPost {
  id                   String                          @id @default(cuid())
  workspaceId          String
  telegramChannelId    String
  title                String
  text                 String?
  imageUrls            String[]                        @default([])
  status               TelegramManagedPostStatus       @default(DRAFT)
  scheduledAt          DateTime?
  publishedAt          DateTime?
  telegramMessageIds   String[]                        @default([])
  telegramMessageUrls  String[]                        @default([])
  telegramRemoteStatus TelegramManagedPostRemoteStatus @default(NONE)
  lastTelegramSyncedAt DateTime?
  lastTelegramSyncNote String?
  sourceType           TelegramSourceType?
  sourceId             String?
  publishMode          String?
  lastError            String?
  assignedMemberId     String
  icon                 String?
  groupId              String?
  groupPosition        Int?
  sidebarPosition      Int?

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  assignedMember  WorkspaceMember @relation("TelegramManagedPostAssignedMember", fields: [assignedMemberId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  group           PostGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, telegramChannelId, createdAt])
  @@index([workspaceId, assignedMemberId])
  @@index([groupId])
  @@index([groupId, groupPosition])
  @@index([telegramChannelId, sidebarPosition])
  @@index([status, scheduledAt])
}

model PostGroup {
  id                String  @id @default(cuid())
  workspaceId       String
  telegramChannelId String
  title             String
  description       String?
  icon              String?
  createdByMemberId String
  sidebarPosition   Int?

  workspace       Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel       @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  createdByMember WorkspaceMember       @relation("PostGroupCreatedByMember", fields: [createdByMemberId, workspaceId], references: [id, workspaceId], onDelete: Restrict)
  posts           TelegramManagedPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([telegramChannelId])
  @@index([createdByMemberId])
  @@index([telegramChannelId, sidebarPosition])
}

model TelegramPostMetricSnapshot {
  id             String   @id @default(cuid())
  telegramPostId String
  viewsCount     Int?
  forwardsCount  Int?
  reactionsCount Int?
  commentsCount  Int?
  reactions      Json?
  collectedAt    DateTime @default(now())

  telegramPost TelegramPost @relation(fields: [telegramPostId], references: [id], onDelete: Cascade)

  @@index([telegramPostId, collectedAt])
}

model ExchangeRate {
  id             String   @id @default(cuid())
  workspaceId    String
  baseCurrency   String   @db.VarChar(3)
  targetCurrency String   @db.VarChar(3)
  rate           Decimal
  date           DateTime
  source         String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, baseCurrency, targetCurrency, date])
}

model Icon {
  id              String   @id @default(cuid())
  workspaceId     String?
  type            IconType
  name            String
  emoji           String?
  imageUrl        String?
  createdByUserId String?

  workspace             Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdByUser         User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  workspaceAvatars      Workspace[]           @relation("WorkspaceAvatarIcon")
  workspaceMembers      WorkspaceMember[]
  accounts              Account[]
  transactions          Transaction[]
  transactionCategories TransactionCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, type, name])
  @@index([workspaceId, name, type])
  @@index([workspaceId, type])
  @@index([createdByUserId])
}
