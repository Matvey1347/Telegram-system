generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  owner
  admin
}

enum Currency {
  UAH
  USD
  EUR
  PLN
}

enum TransactionType {
  income
  expense
}

enum CampaignStatus {
  planned
  active
  finished
  cancelled
  archived
}

enum PromoStatus {
  draft
  active
  archived
}

enum AdvertisingSourceType {
  telegram_channel
  instagram
  facebook
  website
  direct
  other
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  seedKey      String?           @unique
  passwordHash String
  name         String
  memberships  WorkspaceMember[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  primaryCurrency   Currency @default(USD)
  secondaryCurrency Currency @default(UAH)

  members            WorkspaceMember[]
  accounts           Account[]
  transactions       Transaction[]
  transfers          Transfer[]
  telegramChannels   TelegramChannel[]
  telegramBotIntegrations TelegramBotIntegration[]
  telegramBotUpdateLogs TelegramBotUpdateLog[]
  promos             Promo[]
  advertisingSources AdvertisingSource[]
  adCampaigns        AdCampaign[]
  exchangeRates      ExchangeRate[]
  investors          Investor[]
  investments        Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(admin)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
}

model Account {
  id             String   @id @default(cuid())
  workspaceId    String
  name           String
  currency       Currency
  initialBalance Decimal  @default(0)
  isActive       Boolean  @default(true)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  transactions      Transaction[]
  outgoingTransfers Transfer[] @relation("OutgoingTransfers")
  incomingTransfers Transfer[] @relation("IncomingTransfers")
  adCampaigns       AdCampaign[]
  investments       Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id                      String          @id @default(cuid())
  workspaceId              String
  accountId                String
  type                    TransactionType
  amount                  Decimal
  currency                Currency
  amountInPrimaryCurrency Decimal
  exchangeRateToPrimary   Decimal
  category                String
  description             String?
  date                    DateTime
  adCampaignId            String?         @unique
  createdByUserId         String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)

  adCampaign AdCampaign? @relation("CampaignExpenseTransaction", fields: [adCampaignId], references: [id])
  investment Investment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investor {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  notes       String?
  isActive    Boolean  @default(true)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investments Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Investment {
  id                      String   @id @default(cuid())
  workspaceId             String
  investorId              String
  accountId               String
  transactionId           String?  @unique
  amount                  Decimal
  currency                Currency
  amountInPrimaryCurrency Decimal
  exchangeRateToPrimary   Decimal
  date                    DateTime
  notes                   String?
  createdByUserId         String?

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  investor    Investor    @relation(fields: [investorId], references: [id], onDelete: Restrict)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transfer {
  id                  String    @id @default(cuid())
  workspaceId          String
  fromAccountId        String
  toAccountId          String
  fromAmount           Decimal
  fromCurrency         Currency
  toAmount             Decimal
  toCurrency           Currency
  exchangeRate         Decimal?
  expectedToAmount     Decimal?
  transferLossAmount   Decimal?
  transferLossCurrency Currency?
  date                 DateTime
  description          String?
  createdByUserId      String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromAccount Account   @relation("OutgoingTransfers", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount   Account   @relation("IncomingTransfers", fields: [toAccountId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramChannel {
  id                      String   @id @default(cuid())
  workspaceId              String
  title                   String
  username                String?
  telegramChatId           String?
  telegramBotIntegrationId String?
  inviteLink              String?
  description             String?
  language                String?
  niche                   String?
  currentSubscribersCount Int?
  isActive                Boolean  @default(true)

  botStatus               String?
  botIsAdmin              Boolean?
  botCanInviteUsers       Boolean?
  botCanManageChat        Boolean?
  botCanPostMessages      Boolean?
  botCheckedAt            DateTime?
  photoSmallFileId        String?
  photoBigFileId          String?
  photoUrl                String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramBotIntegration TelegramBotIntegration? @relation(fields: [telegramBotIntegrationId], references: [id], onDelete: SetNull)

  promos      Promo[]
  adCampaigns AdCampaign[]
  inviteLinks TelegramInviteLink[]
  dailyStats  TelegramChannelDailyStats[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramChannelDailyStats {
  id                String   @id @default(cuid())
  telegramChannelId String
  date              DateTime
  subscribersCount  Int?
  joinedCount       Int?
  leftCount         Int?
  viewsCount        Int?
  reactionsCount    Int?
  forwardsCount     Int?

  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([telegramChannelId, date])
}

model Promo {
  id                String      @id @default(cuid())
  workspaceId        String
  telegramChannelId  String
  title             String
  text              String
  angle             String?
  imageData         String?
  status            PromoStatus @default(draft)

  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)

  adCampaigns AdCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdvertisingSource {
  id               String                @id @default(cuid())
  workspaceId       String
  name             String
  type             AdvertisingSourceType
  url              String?
  telegramUsername String?
  description      String?
  contactInfo      String?
  notes            String?

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  adCampaigns AdCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdCampaign {
  id                      String         @id @default(cuid())
  workspaceId              String
  telegramChannelId        String
  advertisingSourceId      String?
  promoId                  String?
  accountId                String?

  title                    String
  status                   CampaignStatus @default(planned)
  price                    Decimal
  currency                 Currency
  priceInPrimaryCurrency   Decimal
  exchangeRateToPrimary    Decimal
  inviteLink               String?
  telegramInviteLinkId     String?
  sourcePostUrl            String?
  sourcePostViews          Int?
  startedAt                DateTime?
  endedAt                  DateTime?
  joinedCount              Int            @default(0)
  leftCount                Int?
  netGrowthCount           Int?
  cpa                      Decimal?
  cpm                      Decimal?
  notes                    String?
  createdByUserId          String?

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramChannel   TelegramChannel    @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  advertisingSource AdvertisingSource? @relation(fields: [advertisingSourceId], references: [id], onDelete: SetNull)
  promo             Promo?             @relation(fields: [promoId], references: [id], onDelete: SetNull)
  account           Account?           @relation(fields: [accountId], references: [id], onDelete: SetNull)

  expenseTransaction Transaction? @relation("CampaignExpenseTransaction")

  inviteLinks      TelegramInviteLink[]
  subscriberEvents SubscriberEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramInviteLink {
  id                   String    @id @default(cuid())
  workspaceId           String
  telegramChannelId     String
  adCampaignId          String?
  name                 String
  url                  String
  telegramInviteLinkId  String?
  telegramBotIntegrationId String?
  createdBy            String?
  createsJoinRequest   Boolean?
  expireDate           DateTime?
  memberLimit          Int?
  joinedCount          Int       @default(0)
  isRevoked            Boolean   @default(false)
  lastSyncedAt         DateTime?

  telegramChannel TelegramChannel @relation(fields: [telegramChannelId], references: [id], onDelete: Cascade)
  adCampaign      AdCampaign?     @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)
  telegramBotIntegration TelegramBotIntegration? @relation(fields: [telegramBotIntegrationId], references: [id], onDelete: SetNull)

  subscriberEvents SubscriberEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramBotIntegration {
  id                 String   @id @default(cuid())
  workspaceId        String
  label              String
  botToken           String
  botId              String?
  username           String?
  firstName          String?
  webhookUrl         String?
  webhookActive      Boolean  @default(false)
  hasExternalWebhook Boolean  @default(false)
  webhookSecret      String?
  lastErrorMessage   String?
  lastCheckedAt      DateTime?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels             TelegramChannel[]
  inviteLinks          TelegramInviteLink[]
  updateLogs           TelegramBotUpdateLog[]
}

model TelegramBotUpdateLog {
  id                       String   @id @default(cuid())
  workspaceId              String
  telegramBotIntegrationId String
  updateId                 String?
  updateType               String
  chatId                   String?
  rawUpdate                Json
  processed                Boolean  @default(false)
  errorMessage             String?
  createdAt                DateTime @default(now())

  workspace              Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramBotIntegration TelegramBotIntegration @relation(fields: [telegramBotIntegrationId], references: [id], onDelete: Cascade)
}

model SubscriberEvent {
  id                String   @id @default(cuid())
  workspaceId        String
  telegramChannelId  String
  adCampaignId       String?
  inviteLinkId       String?
  telegramUserId     String?
  eventType          String
  eventDate          DateTime
  source             String?

  adCampaign AdCampaign?        @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)
  inviteLink TelegramInviteLink? @relation(fields: [inviteLinkId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model ExchangeRate {
  id             String   @id @default(cuid())
  workspaceId     String
  baseCurrency    Currency
  targetCurrency  Currency
  rate           Decimal
  date           DateTime
  source         String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, baseCurrency, targetCurrency, date])
}
