DATABASE_URL="postgresql://app:app@localhost:5432/telegram_system?schema=public"
API_PORT=4000
JWT_SECRET="change_me"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
BOT_TOKEN_ENCRYPTION_KEY=""
TELEGRAM_UPDATES_MODE="off"
TELEGRAM_SYNC_ENABLED="true"
TELEGRAM_SYNC_INTERVAL_MINUTES="5"
TELEGRAM_DAILY_ANALYTICS_SYNC_ENABLED="true"

TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""

FRONTEND_URL=""

# Structured application log retention in days. Set 0 to disable automatic cleanup.
APP_LOG_RETENTION_DAYS="90"
# Number of logs to flush to PostgreSQL in one batch.
APP_LOG_BATCH_SIZE="50"
# Flush interval for the in-memory application log queue.
APP_LOG_FLUSH_INTERVAL_MS="1000"
# Minimum stored log level: debug, info, warn, error.
APP_LOG_MIN_LEVEL="all"
# Enable structured HTTP request logging.
APP_LOG_HTTP_ENABLED="true"

B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME==
B2_ENDPOINT=
